COPY ~frenmod/Portraits/fren09S.bmp~ ~override/fren09S.bmp~

// copy charakter-script and creature-file
COMPILE ~frenmod/fren.baf~
	USING ~~
COPY ~frenmod/SHAPE.cre~ ~override/SHAPE.cre~
SAY NAME1 @2
SAY NAME2 @2
SAY BIO @3

// extend scripts
EXTEND_BOTTOM ~VICONIA.bcs~ ~frenmod/vicon.bcs~
EXTEND_BOTTOM ~UDDOOR2.bcs~ ~frenmod/UDDOOR2.bcs~
EXTEND_BOTTOM ~UDDOOR3.bcs~ ~frenmod/UDDOOR3.bcs~


