SAY NAME2 @14
SAY DESC @15

COPY ~frenmod/Items/fren06.itm~ ~override/fren06.itm~
SAY NAME1 @16
SAY NAME2 @16
SAY DESC @17


// compile dialogues
COMPILE ~frenmod/frenJ.d~
USING ~~
COMPILE ~frenmod/frenP.d~
USING ~~

// append 2da entries
APPEND ~pdialog.2da~
	~frendan frenP frenJ frenD~
UNLESS ~frendan~
UNLESS ~25POST~

APPEND ~pdialog.2da~
	~frendan frenP frenJ frenD fren25P fren25J fren25D fren~
UNLESS ~frendan~
IF ~25POST~


// Frennedan's side quest in the Underdark
EXTEND_BOTTOM ~AR2200.bcs~ ~frenmod/Unterreich/AR2200.bcs~
EXTEND_BOTTOM ~AR2100.bcs~ ~frenmod/Unterreich/AR2100.bcs~
EXTEND_BOTTOM ~DWCITY.bcs~ ~frenmod/Unterreich/dwcity.bcs~

