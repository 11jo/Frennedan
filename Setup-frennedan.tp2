COPY ~frenmod/Items/fren01.itm~ ~override/fren01.itm~
SAY NAME1 @7
SAY NAME2 @7
SAY DESC @8

COPY ~frenmod/Items/fren02.itm~ ~override/fren02.itm~
SAY NAME1 @9
