IF
	Global("FrennedanFirstMeet","GLOBAL",0)
	See(Player1)
THEN
	RESPONSE #100
		SetGlobal("FrennedanFirstMeet","GLOBAL",1)
		StartDialogueNoSet(Player1)
END


IF
	GlobalLT("FrennedanFirstMeet","GLOBAL",5)
	PartyHasItem("MISC4P")
THEN
	RESPONSE #100
		SetGlobal("FrennedanFirstMeet","GLOBAL",4)
END


IF
	Global("FrennedanFlucht","GLOBAL",0)
	InParty(Myself)
	AreaCheck("AR0700")
	See(Player1)
	!StateCheck(Player1,STATE_SLEEPING)
THEN
	RESPONSE #100
		SetGlobal("FrennedanFlucht","GLOBAL",1)
		StartDialogueNoSet(Player1)
END


IF
	Global("FrennedanInteract01","GLOBAL",0)
	InParty(Myself)
	InParty("Edwin")
THEN
	RESPONSE #100
		SetGlobal("FrennedanInteract01","GLOBAL",1)
		SetGlobalTimer("FrennedanInteractEdwin","GLOBAL",THREE_DAYS)
END


IF
	Global("FrennedanInteract01","GLOBAL",1)
	InParty(Myself)
	IsValidForPartyDialogue("Edwin")
	GlobalTimerExpired("FrennedanInteractEdwin","GLOBAL")
THEN
	RESPONSE #100
		SetGlobal("FrennedanInteract01","GLOBAL",2)
		StartDialogueNoSet("Edwin")
END


IF
	Global("FrennedanBrynnlaw","GLOBAL",0)
	InParty(Myself)
	AreaCheck("AR1600")
THEN
	RESPONSE #100
		SetGlobal("FrennedanBrynnlaw","GLOBAL",1)
		SetGlobalTimer("FrennedanInteractHC1","GLOBAL",120)
END


IF
	Global("FrennedanBrynnlaw","GLOBAL",1)
	GlobalTimerExpired("FrennedanInteractHC1","GLOBAL")
	InParty(Myself)
	CombatCounter(0)
	!StateCheck(Player1,STATE_SLEEPING)
THEN
	RESPONSE #100
		SetGlobal("FrennedanBrynnlaw","GLOBAL",2)
		StartDialogueNoSet(Player1)
END


IF
	Global("FrennedanUnterreich","GLOBAL",0)
	InParty(Myself)
	AreaCheck("AR2100")
	!StateCheck(Player1,STATE_SLEEPING)
THEN
	RESPONSE #100
		SetGlobal("FrennedanUnterreich","GLOBAL",1)
		Wait(1)
		StartDialogueNoSet(Player1)
END


IF
	Global("FrennedanUnterreich","GLOBAL",2)
	InParty(Myself)
	AreaCheck("AR2102")
	See(Player1)
	!StateCheck(Player1,STATE_SLEEPING)
THEN
	RESPONSE #100
		SetGlobal("FrennedanUnterreich","GLOBAL",3)
