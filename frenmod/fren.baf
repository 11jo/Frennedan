IF
	Global("FrennedanUnterreich","GLOBAL",5)
	InParty(Myself)
	See(Player1)
	!StateCheck(Player1,STATE_SLEEPING)
THEN
	RESPONSE #100
		MoveToObject(Player1)
		StartDialogueNoSet(Player1)
