IF
	Die()
	GlobalLT("FrennedanSpeicher","GLOBAL",4)
THEN
	RESPONSE #100
		SetGlobal("FrennedanTod","GLOBAL",1)
END


IF
	Die()
	Global("FrennedanSpeicher","GLOBAL",4)
THEN
	RESPONSE #100
		SetGlobal("FrennedanTod","GLOBAL",2)
END


IF
	Global("FrennedanTod","GLOBAL",1)
	!Dead("frendan")
THEN
	RESPONSE #100
		SetGlobal("FrennedanTod","GLOBAL",0)
		ReallyForceSpellRES("fraufw02",Myself)
		SetGlobal("FrennedanAufwertung","GLOBAL",0)
END


