IF
	Global("FrennedanUnterreich","GLOBAL",7)
	InParty(Myself)
	See(Player1)
	!StateCheck(Player1,STATE_SLEEPING)
THEN
	RESPONSE #100
		SetGlobal("FrennedanUnterreich","GLOBAL",8)
		StartDialogueNoSet(Player1)
END


IF
	AttackedBy([PC.0.0],DEFAULT)
	Allegiance(Myself,NEUTRAL)
	Global("FrennedanSpeak","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("FrennedanSpeak","LOCALS",1)
		SetGlobal("FMorph","GLOBAL",1)
		ReallyForceSpellRES("fraufw02",Myself)
		DisplayStringHead(Myself,"Was?! Ihr greift mich an?!")
		Wait(2)
		DisplayStringHead(Myself,"Dann werde ich euch alle töten, ihr Dummköpfe!")
		CreateVisualEffectObject("SPFLESHS",Myself)
		SetGlobal("Frennedan","AR0603",2)
		Enemy()
		CreateVisualEffectObject("SPFLESHS",Myself)
		Polymorph(DOPPLEGANGER)
		ChangeAIScript("WTASIGHT",DEFAULT)
		SetInterrupt(TRUE)
END


IF
	Global("FrennedanAufwertung","GLOBAL",0)
	InParty(Myself)
	XPGT(Player1,500000)
THEN
	RESPONSE #100
		SetGlobal("FrennedanAufwertung","GLOBAL",1)
		ReallyForceSpellRES("fraufw03",Myself)
		ReallyForceSpell(Myself,RED_PILLAR_VISUAL)
END

IF
	Global("FrennedanAufwertung","GLOBAL",1)
	InParty(Myself)
	XPGT(Player1,1750000)
THEN
	RESPONSE #100
		SetGlobal("FrennedanAufwertung","GLOBAL",2)
		ReallyForceSpellRES("fraufw04",Myself)
		ReallyForceSpell(Myself,RED_PILLAR_VISUAL)
END


IF
	See(NearestEnemyOf(Myself))
	ActuallyInCombat()
	!Global("FMorph","GLOBAL",1)
	!Global("FrennedanSpeicher","GLOBAL",4)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("FMorph","GLOBAL",1)
		CreateVisualEffectObject("SPFLESHS",Myself)
		ReallyForceSpellRES("fren00",Myself)		
		Polymorph(DOPPLEGANGER)
		SetPlayerSound(Myself,-1,MORALE)
		SetPlayerSound(Myself,-1,HAPPY)
		SetPlayerSound(Myself,-1,UNHAPPY_BREAKING_POINT)
		SetPlayerSound(Myself,5884,DAMAGE)
		SetPlayerSound(Myself,5885,DYING)
		SetPlayerSound(Myself,5165,SELECT_COMMON1)
		SetPlayerSound(Myself,5166,SELECT_COMMON2)
		SetPlayerSound(Myself,5167,SELECT_COMMON3)
		SetPlayerSound(Myself,-1,SELECT_COMMON4)
		SetInterrupt(TRUE)
END


