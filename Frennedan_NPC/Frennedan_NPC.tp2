// copy charakter-script and creature-file
COMPILE ~Frennedan_NPC/Baf/fren.baf~ // USING ~~
COPY_EXISTING ~SHAPE.cre~ ~override~ // BWP Fix
SAY NAME1 @2
SAY NAME2 @2
SAY BIO @3
WRITE_LONG 0x14 ~6000~
WRITE_LONG 0x18 ~850000~
WRITE_SHORT 0x24 ~79~
WRITE_SHORT 0x26 ~79~
WRITE_BYTE 0x2c 27
WRITE_BYTE 0x2d 18
WRITE_BYTE 0x2e 20
WRITE_BYTE 0x2f 84
WRITE_BYTE 0x30 26
WRITE_BYTE 0x31 30
WRITE_BYTE 0x32 84
WRITE_ASCII 0x34 ~FREN01S~ #8
WRITE_ASCII 0x3c ~FREN01L~ #8
WRITE_SHORT 0x46 ~-4~
WRITE_BYTE 0x52 6
WRITE_BYTE 0x54 8
WRITE_BYTE 0x55 10
WRITE_BYTE 0x56 4
WRITE_BYTE 0x57 9
WRITE_BYTE 0x58 11
WRITE_BYTE 0x5d 35
WRITE_BYTE 0x60 0
WRITE_BYTE 0x61 0
WRITE_BYTE 0x62 0
WRITE_BYTE 0x63 0
WRITE_BYTE 0x66 24
WRITE_BYTE 0x234 11
WRITE_BYTE 0x235 0
WRITE_BYTE 0x236 0
WRITE_BYTE 0x237 1
WRITE_BYTE 0x23f 10
WRITE_BYTE 0x240 0
WRITE_BYTE 0x242 1
WRITE_ASCII 0x248 ~FREN~ #8
WRITE_ASCII 0x250 ~~ #8
WRITE_ASCII 0x258 ~~ #8
WRITE_ASCII 0x260 ~~ #8
WRITE_ASCII 0x268 ~~ #8
WRITE_BYTE 0x273 2
WRITE_BYTE 0x275 1
WRITE_ASCII 0x280 ~FRENDAN~ #32
WRITE_ASCII 0x2cc ~FRENJ~ #8
ADD_CRE_ITEM ~FREN01~ #0 #0 #0 ~NONE~ ~ARMOR~
ADD_CRE_ITEM ~FREN02~ #0 #0 #0 ~NONE~ ~WEAPON~

// extend scripts
EXTEND_BOTTOM ~VICONIA.bcs~ ~Frennedan_NPC/Baf/vicon.baf~
EXTEND_BOTTOM ~UDDOOR2.bcs~ ~Frennedan_NPC/Baf/UDDOOR2.baf~
EXTEND_BOTTOM ~UDDOOR3.bcs~ ~Frennedan_NPC/Baf/UDDOOR3.baf~

// Silver star comptat // BWP Fix
ACTION_IF (MOD_IS_INSTALLED ~Star.tp2~ 0) BEGIN
	EXTEND_BOTTOM ~AR0603.BCS~ ~frenmod/AR0603.baf~
END


// copy spells and items
OUTER_SPRINT "Fren_Polymorph" "Fren_Polymorph"
COPY ~Frennedan_NPC/Spells/frenm.spl~ ~override/frenm.spl~
	SAY NAME1 @4
	SAY NAME2 @4
	LPF ALTER_SPELL_EFFECT
		INT_VAR
			check_headers = 1			
			match_opcode = 265
		STR_VAR
			resource = EVAL ~%Fren_Polymorph%~
		END

