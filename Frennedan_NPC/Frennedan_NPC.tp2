// compile dialogues
COMPILE ~Frennedan_NPC/D/frenJ.d~ // USING ~~
COMPILE ~Frennedan_NPC/D/frenP.d~ // USING ~~

// append 2da entries
APPEND ~pdialog.2da~
	~frendan frenP frenJ frenD~
UNLESS ~frendan~
UNLESS ~25POST~

APPEND ~pdialog.2da~
	~frendan frenP frenJ frenD fren25P fren25J fren25D fren~
UNLESS ~frendan~
IF ~25POST~


